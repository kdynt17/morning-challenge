{
  "rules": {
    ".read": false,
    ".write": false,

    "users": {
      ".indexOn": ["points", "email"],
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() == 'teacher' || (!data.exists() && auth.uid == $uid && newData.child('role').val() == 'student' && newData.child('points').val() == 0 && newData.child('email').val() == auth.token.email) || (!data.exists() && auth.uid == $uid && auth.token.email == 'admin@admin.com' && newData.child('role').val() == 'teacher'))",
        ".validate": "newData.hasChildren(['email', 'role', 'points', 'name'])"
      }
    },

    "dailyChallenges": {
      "$dateKey": {
        ".read": "auth != null",
        ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() == 'teacher'"
      }
    },

    "challengeAnswers": {
      "$dateKey": {
        ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() == 'teacher'",
        ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() == 'teacher'"
      }
    },

    "submissions": {
      "$submissionId": {
        ".read": "auth != null && (data.child('uid').val() == auth.uid || root.child('users').child(auth.uid).child('role').val() == 'teacher')",
        ".write": "auth != null && (!data.exists() && newData.child('uid').val() == auth.uid && newData.child('status').val() == 'pending')"
      }
    },

    "challengeWinners": {
      "$winnerId": {
        ".read": "auth != null",
        ".write": false
      }
    },

    "auctions": {
      ".read": "auth != null",
      ".indexOn": ["visible", "endsAt"],
      "$auctionId": {
        ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() == 'teacher'"
      }
    },

    "bids": {
      "$bidId": {
        ".read": "auth != null && (data.child('uid').val() == auth.uid || root.child('users').child(auth.uid).child('role').val() == 'teacher')",
        ".write": "auth != null && !data.exists() && newData.child('uid').val() == auth.uid && newData.child('amount').isNumber() && newData.child('amount').val() > 0"
      }
    }
  }
}
